DB_NAME=grtr_homes
# Local development URL. In production, set this to your deployed app URL.
# Example: https://grtrhomes.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH0_CLIENT_ID=replace-with-auth0-client-id
